#include <stdio.h>
#include <math.h>

int main()
{
    int n, i, f;
    scanf("%d", &n);

    if(n<2)
        printf("NO");

    else if(n==2)
        printf("YES");

    else if(n%2==0)
        printf("NO");

    else if(n>2)
    {
        f=0;
        for(i=3; i<=sqrt(n); i=i+2)
        {
            if(n%i==0)
            {
                printf("NO");
                f=1;
                break;

            }
        }
        if(f==0)
            printf("YES");
    }

    return 0;
}
