#include <stdio.h>
#include <math.h>

int main()
{
    int n, f, i, j;
    scanf("%d", &n);

    if(n>=2)
        printf("2");

    for(i=3; i<=n; i=i+2)
    {
        f=0;
        for(j=3; j<=sqrt(i); j=j+2)
        {
            if(i%j==0)
            {
                f=1;
                break;
            }

        }
        if(f==0)
            printf(" %d", i);
    }

    return 0;
}
