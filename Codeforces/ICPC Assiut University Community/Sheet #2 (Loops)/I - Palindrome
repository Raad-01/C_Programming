#include <stdio.h>

int main()
{
    int n, m, r, val = 0;
    scanf("%d", &n);
    m = n;

    while(n != 0)
    {
        r = n % 10;
        n = n / 10;
        val = val * 10 + r;
    }

    printf("%d\n", val);

    if(m == val)
        printf("YES\n");
    else
        printf("NO\n");

    return 0;
}
