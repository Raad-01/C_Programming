#include <stdio.h>

int main()
{
    int t, i, m, r;
    scanf("%d", &t);
    for(i=1; i<=t; i++)
    {
    	scanf("%d", &m);
    	if(m==0)
    		printf("0\n");
    	else
    	{	
    		while(m!=0)
    		{
    			r = m%10;
    			printf("%d ", r);
    			m = m/10;
    		}
    		printf("\n");
    	}
    }
    return 0;
}
