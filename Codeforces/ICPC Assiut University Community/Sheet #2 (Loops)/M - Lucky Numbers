#include <stdio.h>

int main()
{
	int a, b, i, n, r, f, x=0;
	scanf("%d%d", &a, &b);
	for(i=a; i<=b; i++)
	{
		n=i;
		f=0;
		while(n!=0)
		{
			r = n%10;
			if(r!=4 && r!=7)
			{
				f=1;
				break;
			}
			n = n/10;
		}
		if(f==0)
		{
			if(x>0)
				printf(" ");
			
			printf("%d", i);
			x++;
		}	
	}
	if(x==0)
		printf("-1");
		
	return 0;
}
