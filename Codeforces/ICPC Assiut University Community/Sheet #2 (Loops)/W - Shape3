#include <stdio.h>

int main()
{
	int n, m, i, j, k;
	scanf("%d", &n);
	
	m = n;
	
	for(i=1; i<=n; i++)
	{
		for(j=m-1; j>0; j--)
			printf(" ");
			
		m--;
		
		for(k=1; k<=2*i-1; k++)
			printf("*");
			
		printf("\n");
	}
	
	m = n;
	
	for(i=1; i<=n; i++)
	{
		for(j=1; j<i; j++)
			printf(" ");
		
		for(k=2*m-1; k>=1; k--)
			printf("*");
		
		m--;
			
		printf("\n");
	}
	
    return 0;
}
